{
  "expo": {
    "name": "Talko",
    "slug": "ielts-master",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "ielts-master",
      "com.googleusercontent.apps.109247400665-uankemndfn8h3j8klla9b44hof4ctb0k"
    ],
    "jsEngine": "jsc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ieltsmaster.app",
      "associatedDomains": [
        "applinks:ielts-platform.pages.dev"
      ],
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to evaluate your speaking practice.",
        "NSMicrophoneUsageDescription": "This app needs microphone access to record your speaking practice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ielts-platform.pages.dev",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.ieltsmaster.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-av",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0058be",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Talko"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f99ff069-a2c9-463c-8a8f-98ba145ab7cb"
      }
    }
  }
}
